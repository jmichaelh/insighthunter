{
    "$schema": "https://turbo.build/schema.json",
    "ui": "tui",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "inputs":    ["$TURBO_DEFAULT$", ".env.local"],
        "outputs":   ["dist/**", ".astro/**"]
      },
      "dev": {
        "cache":     false,
        "persistent": true
      },
      "deploy": {
        "dependsOn": ["build"],
        "cache":     false
      },
      "typecheck": {
        "dependsOn": ["^typecheck"]
      },
      "lint": {
        "dependsOn": ["^lint"]
      },
      "clean": {
        "cache": false
      }
    }
  }
  