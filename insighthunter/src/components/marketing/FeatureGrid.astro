---
import { HERO_FEATURES } from '~/data/features';
import Badge from '~/components/shared/Badge.astro';
---

<section class="section-pad" style="background:#f8f5f0;">
  <div class="container-mkt">
    <div class="fg-header">
      <Badge text="Features" variant="green" />
      <h2 class="fg-title">Everything Your Business Needs to See Clearly</h2>
      <p class="fg-sub">
        From solo freelancers to fractional CFO firms — InsightHunter scales with you.
        No accounting degree required.
      </p>
    </div>

    <div class="fg-grid">
      {HERO_FEATURES.map((f, i) => (
        <div class="feature-card" style={`animation-delay:${i * 0.05}s`}>
          <div class="fc-icon">{f.icon}</div>
          <h3 class="fc-title">{f.title}</h3>
          <p class="fc-desc">{f.description}</p>
          <span class={`fc-tier fc-tier--${f.tier}`}>{f.tier === 'lite' ? 'Free' : f.tier.charAt(0).toUpperCase() + f.tier.slice(1)}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
@use '~/styles/theme' as *;

.fg-header {
  text-align: center;
  max-width: 640px;
  margin: 0 auto 4rem;
}

.fg-title {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 800;
  color: $mkt-text;
  letter-spacing: -0.02em;
  margin: 1rem 0 1rem;
  line-height: 1.2;
}

.fg-sub {
  font-size: 1.0625rem;
  color: $mkt-text-muted;
  line-height: 1.7;
}

.fg-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.25rem;
}

.fc-icon {
  font-size: 2rem;
  margin-bottom: 0.75rem;
  display: block;
}

.fc-title {
  font-size: 1rem;
  font-weight: 700;
  color: $mkt-text;
  margin-bottom: 0.5rem;
}

.fc-desc {
  font-size: 0.875rem;
  color: $mkt-text-muted;
  line-height: 1.6;
  flex: 1;
}

.fc-tier {
  display: inline-block;
  margin-top: 1rem;
  font-size: 0.6875rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 0.2rem 0.6rem;
  border-radius: $radius-full
