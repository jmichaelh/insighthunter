---
import Button from '~/components/shared/Button.astro';
---

<section class="hero-section">
  <div class="container-mkt hero-inner">
    <div class="hero-content">
      <!-- Badge -->
      <div class="hero-badge animate-fade-up">
        <span class="hero-badge-dot"></span>
        AI-Powered · Built on Cloudflare · No Setup Required
      </div>

      <!-- Headline -->
      <h1 class="hero-title animate-fade-up" style="animation-delay:0.1s">
        Stop Flying Blind.<br />
        <span class="gradient-text">Your Auto-CFO</span><br />
        Is Here.
      </h1>

      <!-- Subhead -->
      <p class="hero-sub animate-fade-up" style="animation-delay:0.2s">
        InsightHunter gives freelancers, small businesses, and fractional CFOs
        enterprise-grade financial intelligence — P&amp;L dashboards, cash flow forecasts,
        AI insights, and more — in minutes, not months.
      </p>

      <!-- Social proof numbers -->
      <div class="hero-stats animate-fade-up" style="animation-delay:0.25s">
        <div class="hero-stat">
          <span class="hero-stat-num">65M+</span>
          <span class="hero-stat-label">Target Freelancers</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">$100B</span>
          <span class="hero-stat-label">Market Size</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">&lt;30s</span>
          <span class="hero-stat-label">First Report</span>
        </div>
      </div>

      <!-- CTAs -->
      <div class="hero-ctas animate-fade-up" style="animation-delay:0.3s">
        <a href="/auth/register" class="hero-cta-primary">
          Start Free — No Credit Card
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
        <a href="/pricing" class="hero-cta-ghost">View Pricing</a>
      </div>
    </div>

    <!-- Hero Visual / Dashboard Preview -->
    <div class="hero-visual animate-fade-up" style="animation-delay:0.35s">
      <div class="hero-dashboard-preview">
        <!-- Mock KPI Row -->
        <div class="hdp-topbar">
          <span class="hdp-title">💼 Dashboard — Q1 2026</span>
          <span class="hdp-badge">Live</span>
        </div>
        <div class="hdp-kpi-row">
          <div class="hdp-kpi hdp-kpi--green">
            <span class="hdp-kpi-label">Revenue</span>
            <span class="hdp-kpi-val">$84,200</span>
            <span class="hdp-kpi-delta">▲ 12.4%</span>
          </div>
          <div class="hdp-kpi hdp-kpi--blue">
            <span class="hdp-kpi-label">Net Profit</span>
            <span class="hdp-kpi-val">$31,540</span>
            <span class="hdp-kpi-delta">▲ 8.1%</span>
          </div>
          <div class="hdp-kpi hdp-kpi--gold">
            <span class="hdp-kpi-label">Cash Flow</span>
            <span class="hdp-kpi-val">$18,900</span>
            <span class="hdp-kpi-delta">▲ 5.3%</span>
          </div>
        </div>
        <!-- Mock Chart -->
        <div class="hdp-chart-area">
          <div class="hdp-chart-label">Cash Flow Forecast — 12 Months</div>
          <div class="hdp-chart-bars">
            {[65,72,68,81,78,90,85,94,88,102,98,110].map((h, i) => (
              <div class="hdp-bar-wrap">
                <div class="hdp-bar" style={`height:${h}%;background:${i >= 6 ? 'rgba(34,197,94,0.5)' : 'rgba(34,197,94,0.8)'};`}></div>
              </div>
            ))}
          </div>
          <div class="hdp-chart-foot">
            <span>Jan</span><span>Mar</span><span>Jun</span><span>Sep</span><span>Dec</span>
          </div>
        </div>
        <!-- AI Insight bubble -->
        <div class="hdp-insight">
          <span class="hdp-insight-icon">🧠</span>
          <span>AI Insight: Revenue trending +12% — strong Q2 outlook. Watch payroll costs.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@use '~/styles/theme' as *;

.hero-section {
  background: linear-gradient(135deg, #0d0d1a 0%, #1a1a2e 45%, #0f2040 100%);
  padding: 5rem 0 4rem;
  position: relative;
  overflow: hidden;

  @include responsive($bp-lg) { padding: 7rem 0 6rem; }

  &::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(34,197,94,0.08) 0%, transparent 70%);
  }
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
  position: relative;
  z-index: 1;

  @include responsive($bp-lg) { grid-template-columns: 1fr 1fr; gap: 4rem; }
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  font-weight: 500;
  color: rgba(241,245,249,0.7);
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: $radius-full;
  padding: 0.375rem 0.875rem;
  margin-bottom: 1.5rem;

  &-dot {
    width: 6px; height: 6px;
    background: $color-accent;
    border-radius: 50%;
    animation: pulse-glow 2s infinite;
  }
}

.hero-title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: #f1f5f9;
  margin-bottom: 1.5rem;
}

.hero-sub {
  font-size: 1.0625rem;
  line-height: 1.7;
  color: rgba(241,245,249,0.7);
  max-width: 520px;
  margin-bottom: 2rem;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}

.hero-stat {
  display: flex;
  flex-direction: column;

  &-num   { font-size: 1.5rem; font-weight: 800; color: #f1f5f9; letter-spacing: -0.03em; }
  &-label { font-size: 0.75rem; color: rgba(241,245,249,0.5); }

  &-divider {
    width: 1px;
    height: 2.5rem;
    background: rgba(255,255,255,0.12);
  }
}

.hero-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  align-items: center;
}

.hero-cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.875rem 1.75rem;
  background: $color-accent;
  color: #000;
  font-weight: 700;
  font-size: 0.9375rem;
  border-radius: $radius-lg;
  @include transition;

  &:hover { background: #16a34a; transform: translateY(-2px); box-shadow: $shadow-glow-green; }
}

.hero-cta-ghost {
  padding: 0.875rem 1.5rem;
  color: rgba(241,245,249,0.8);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: $radius-lg;
  font-weight: 500;
  font-size: 0.9375rem;
  @include transition;

  &:hover { border-color: rgba(255,255,255,0.3); color: #f1f5f9; }
}

// ─── Dashboard Preview ────────────────────────────────────────────────────────
.hero-visual {
  @media (max-width: #{$bp-lg}) { display: none; }
}

.hero-dashboard-preview {
  background: rgba(26,26,46,0.9);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 1.25rem;
  overflow: hidden;
  box-shadow: 0 24px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(34,197,94,0.1);
  animation: float 4s ease-in-out infinite;
}

.hdp-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.875rem 1.25rem;
  border-bottom: 1px solid rgba(255,255,255,0.07);
  font-size: 0.8125rem;
  font-weight: 600;
  color: #94a3b8;
}

.hdp-badge {
  font-size: 0.625rem;
  background: rgba(34,197,94,0.15);
  color: #22c55e;
  border: 1px solid rgba(34,197,94,0.3);
  padding: 0.125rem 0.5rem;
  border-radius: $radius-full;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.hdp-kpi-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-bottom: 1px solid rgba(255,255,255,0.07);
}

.hdp-kpi {
  padding: 1rem;
  border-right: 1px solid rgba(255,255,255,0.07);
  display: flex;
  flex-direction: column;
  gap: 0.125rem;

  &:last-child { border-right: none; }

  &-label { font-size: 0.65rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
  &-val   { font-size: 1.1rem; font-weight: 700; color: #f1f5f9; }
  &-delta { font-size: 0.7rem; font-weight: 600; }

  &--green .hdp-kpi-delta { color: #22c55e; }
  &--blue  .hdp-kpi-delta { color: #60a5fa; }
  &--gold  .hdp-kpi-delta { color: #f59e0b; }
}

.hdp-chart-area {
  padding: 1rem 1.25rem 0.5rem;
}

.hdp-chart-label {
  font-size: 0.7rem;
  color: #64748b;
  margin-bottom: 0.75rem;
}

.hdp-chart-bars {
  display: flex;
  align-items: flex-end;
  gap: 3px;
  height: 80px;
}

.hdp-bar-wrap {
  flex: 1;
  height: 100%;
  display: flex;
  align-items: flex-end;
}

.hdp-bar {
  width: 100%;
  border-radius: 2px 2px 0 0;
  @include transition;
}

.hdp-chart-foot {
  display: flex;
  justify-content: space-between;
  font-size: 0.6rem;
  color: #64748b;
  margin-top: 0.375rem;
  padding-bottom: 0.25rem;
}

.hdp-insight {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  padding: 0.875rem 1.25rem;
  background: rgba(34,197,94,0.06);
  border-top: 1px solid rgba(34,197,94,0.12);
  font-size: 0.75rem;
  color: rgba(241,245,249,0.8);
  line-height: 1.5;

  &-icon { font-size: 1rem; flex-shrink: 0; margin-top: 0.1rem; }
}
</style>
