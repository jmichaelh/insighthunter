{
  "name": "insighthunter-main",
  "type": "module",
  "version": "2.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler pages dev ./dist",
    "deploy": "astro build && wrangler pages deploy ./dist --project-name=insighthunter",
    "typecheck": "astro check && tsc --noEmit",
    "auth-worker:dev": "cd workers/auth-worker && wrangler dev",
    "auth-worker:deploy": "cd workers/auth-worker && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.3.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/svelte": "^7.0.0",
    "astro": "^5.5.0",
    "chart.js": "^4.4.8",
    "hono": "^4.7.0",
    "svelte": "^5.23.0",
    "svelte-chartjs": "^3.1.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.3",
    "sass": "^1.86.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "wrangler": "^3.109.3"
  }
}
