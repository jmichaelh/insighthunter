{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*":           ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@stores/*":     ["./src/stores/*"],
      "@lib/*":        ["./src/lib/*"]
    },
    "types": ["@cloudflare/workers-types"],
    "allowImportingTsExtensions": true
  },
  "include": ["src", "worker", "astro.config.mjs"]
}
