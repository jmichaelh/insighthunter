{
  "name": "bizforma",
  "version": "2.0.0",
  "description": "InsightHunters — Business Formation Assistant (Astro + Svelte + Hono + Cloudflare)",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "worker:dev": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "db:create": "wrangler d1 create bizforma_db",
    "db:init": "wrangler d1 execute bizforma_db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute bizforma_db --local --file=./schema.sql",
    "kv:create": "wrangler kv namespace create BUSINESS_DATA",
    "r2:create": "wrangler r2 bucket create bizforma-documents",
    "setup": "npm run db:create && npm run kv:create && npm run r2:create && npm run db:init",
    "type-check": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "@astrojs/svelte": "^7.0.0",
    "@astrojs/tailwind": "^5.1.3",
    "astro": "^5.0.0",
    "astro-seo": "^0.8.4",
    "hono": "^4.7.5",
    "svelte": "^5.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250307.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.0.0"
  }
}
