---
export interface Props {
  eyebrow?: string;
  title:    string;
  sub?:     string;
  centered?: boolean;
}

const { eyebrow, title, sub, centered = true } = Astro.props;
---

<div class:list={['section-header', centered && 'section-header--centered']}>
  {eyebrow && <p class="section-header__eyebrow">{eyebrow}</p>}
  <h2 class="section-header__title">{title}</h2>
  {sub && <p class="section-header__sub">{sub}</p>}
</div>

<style>
  .section-header { margin-bottom: 1rem; }
  .section-header--centered { text-align: center; }

  .section-header__eyebrow {
    font-size:      0.78rem;
    font-weight:    700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color:          var(--color-primary);
    margin-bottom:  0.5rem;
  }

  .section-header__title {
    font-size:     2rem;
    font-weight:   800;
    color:         var(--color-text);
    line-height:   1.2;
    margin-bottom: 0.875rem;
  }

  .section-header__sub {
    font-size:  1rem;
    color:      var(--color-text-muted);
    line-height: 1.7;
    max-width:  640px;
  }
  .section-header--centered .section-header__sub { margin-inline: auto; }
</style>
