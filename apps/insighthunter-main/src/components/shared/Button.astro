---
export interface Props {
  variant?: 'primary' | 'ghost' | 'outline' | 'danger';
  size?:    'sm' | 'md' | 'lg';
  href?:    string;
  type?:    'button' | 'submit' | 'reset';
  disabled?: boolean;
  full?:    boolean;
  class?:   string;
}

const {
  variant  = 'primary',
  size     = 'md',
  href,
  type     = 'button',
  disabled = false,
  full     = false,
  class: extraClass = '',
} = Astro.props;

const classes = [
  'btn',
  `btn--${variant}`,
  size !== 'md' ? `btn--${size}` : '',
  full ? 'btn--full' : '',
  extraClass,
].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes}><slot /></a>
) : (
  <button type={type} class={classes} disabled={disabled}><slot /></button>
)}
