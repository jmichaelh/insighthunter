---
// apps/insighthunter-main/src/pages/index.astro
import MarketingLayout from '../layouts/MarketingLayout.astro';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import Hero from '../components/ui/Hero.astro';
import FeatureCard from '../components/ui/FeatureCard.astro';
import PricingCard from '../components/ui/PricingCard.astro';
import PlanSelector from '../components/islands/shop/PlanSelector.svelte';
---

<MarketingLayout
  title="InsightHunter — AI-Powered CFO Workspace"
  description="Stop flying blind. InsightHunter gives freelancers and small businesses enterprise-grade financial clarity — automated reports, compliance tracking, AI forecasting, and more."
  canonical="https://insighthunter.app"
>

  <Nav />

  <!-- ─── HERO ─────────────────────────────────────────────────────────────── -->

  <Hero
    headline="Your Business Deserves a CFO."
    subheadline="Stop Flying Blind."
    body="InsightHunter automates your financial reporting, compliance tracking, cash flow forecasting, and client insights — so you run your business with clarity, not guesswork."
    ctaPrimary={{ label: "Start Free — No Credit Card", href: "/auth/signup" }}
    ctaSecondary={{ label: "See How It Works", href: "#features" }}
    badge="AI-Powered CFO Workspace"
  />

  <!-- ─── SOCIAL PROOF BAR ──────────────────────────────────────────────────── -->

  <section class="proof-bar" aria-label="Trust indicators">
    <div class="container">
      <ul class="proof-list" role="list">
        <li>
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M10 1L12.39 6.26L18 7.27L14 11.14L14.76 17L10 14.27L5.24 17L6 11.14L2 7.27L7.61 6.26L10 1Z" fill="currentColor"/>
          </svg>
          Built on Cloudflare — 99.99% uptime, global edge
        </li>
        <li>
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" fill="currentColor"/>
          </svg>
          Free tier — 3 clients, no time limit
        </li>
        <li>
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" fill="currentColor"/>
          </svg>
          SOC 2-aligned data handling
        </li>
        <li>
          <svg aria-hidden="true" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" fill="currentColor"/>
          </svg>
          Built for 65M+ freelancers &amp; small firms
        </li>
      </ul>
    </div>
  </section>

  <!-- ─── PROBLEM → SOLUTION ───────────────────────────────────────────────── -->

  <section class="section section--alt" id="solution" aria-labelledby="solution-heading">
    <div class="container container--narrow">
      <div class="section-label">The Problem</div>
      <h2 id="solution-heading" class="section-heading">
        QuickBooks tracks your books.<br />
        <span class="text-accent">InsightHunter tells you what to do next.</span>
      </h2>
      <p class="section-body">
        Bookkeeping software records transactions — it doesn't warn you about cash shortfalls,
        flag overdue compliance, generate client-ready reports, or forecast your next quarter.
        That's what a CFO does. That's what InsightHunter does — automatically.
      </p>

      <div class="comparison-grid" role="table" aria-label="InsightHunter vs traditional bookkeeping">
        <div class="comparison-col" role="row">
          <div class="comparison-head comparison-head--bad" role="columnheader">Traditional Bookkeeping</div>
          <ul class="comparison-list comparison-list--bad" role="cell">
            <li>Manual report exports</li>
            <li>No cash flow alerts</li>
            <li>Compliance tracked in spreadsheets</li>
            <li>Client reports take hours</li>
            <li>Zero forecasting</li>
            <li>No AI, no automation</li>
          </ul>
        </div>
        <div class="comparison-divider" aria-hidden="true">VS</div>
        <div class="comparison-col" role="row">
          <div class="comparison-head comparison-head--good" role="columnheader">InsightHunter</div>
          <ul class="comparison-list comparison-list--good" role="cell">
            <li>Auto-generated Insight Packs</li>
            <li>Real-time KPI &amp; cash flow alerts</li>
            <li>Unified compliance dashboard</li>
            <li>One-click branded PDF reports</li>
            <li>AI-powered 3-month forecasts</li>
            <li>Automated reminders &amp; workflows</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FOUR PILLARS ─────────────────────────────────────────────────────── -->

  <section class="section" id="features" aria-labelledby="features-heading">
    <div class="container">
      <div class="section-label">The Platform</div>
      <h2 id="features-heading" class="section-heading">
        Four pillars. One workspace.
      </h2>
      <p class="section-body">
        Every feature works together from day one — no integrations required, no duct tape.
      </p>

      <div class="features-grid">

        <FeatureCard
          icon="compliance"
          label="01"
          title="Compliance Hub"
          description="Never miss a deadline. Track every client's compliance status, due dates, and document history in one dashboard. Generate audit-ready records and e-sign engagement letters in seconds."
          highlights={[
            "Due date visibility across all clients",
            "Engagement letter generation + e-sign",
            "Full audit-ready document history",
            "Automated deadline reminders",
          ]}
          href="/features/bookkeeping"
          plan="lite"
        />

        <FeatureCard
          icon="ledger"
          label="02"
          title="Bookkeeping & Ledgers"
          description="Reconciliations with a clear audit trail. Standardized chart-of-accounts templates by industry, clean ledger views, and financials ready to send to owners and stakeholders."
          highlights={[
            "Bank reconciliation with audit trail",
            "Industry chart-of-accounts templates",
            "Stakeholder-ready financial statements",
            "AI-assisted transaction categorization",
          ]}
          href="/features/bookkeeping"
          plan="standard"
        />

        <FeatureCard
          icon="reports"
          label="03"
          title="Reporting & Insight Packs"
          description="One click. One polished PDF. White-label branded Insight Packs your clients will actually read — P&L, cash flow, KPIs, and variance analysis, all formatted and ready to send."
          highlights={[
            "One-click Insight Pack PDF generation",
            "White-label branding for Pro firms",
            "P&L, cash flow, KPI in every pack",
            "Template-driven engagement letters",
          ]}
          href="/features/insight-standard"
          plan="standard"
        />

        <FeatureCard
          icon="ai"
          label="04"
          title="AI Automation & Forecasting"
          description="Your always-on CFO assistant. Cash flow trends, KPI dashboards, forecast alerts, and an AI chat interface that answers questions about your numbers — with your actual data."
          highlights={[
            "3-month AI cash flow forecast",
            "KPI health score + anomaly alerts",
            "AI CFO chat with financial context",
            "Automated recurring workflow rules",
          ]}
          href="/features/insight-pro"
          plan="pro"
        />

      </div>
    </div>
  </section>

  <!-- ─── HOW IT WORKS ─────────────────────────────────────────────────────── -->

  <section class="section section--alt" id="how-it-works" aria-labelledby="how-heading">
    <div class="container container--narrow">
      <div class="section-label">How It Works</div>
      <h2 id="how-heading" class="section-heading">
        From signup to first insight<br />in under 5 minutes.
      </h2>

      <ol class="steps-list" role="list">
        <li class="step">
          <div class="step-number" aria-hidden="true">01</div>
          <div class="step-content">
            <h3 class="step-title">Create your free account</h3>
            <p class="step-body">
              Sign up in seconds — no credit card required. Lite plan gives you 3
              client profiles, manual CSV upload, and standard compliance tracking, free forever.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-number" aria-hidden="true">02</div>
          <div class="step-content">
            <h3 class="step-title">Add a client &amp; upload your data</h3>
            <p class="step-body">
              Add a client profile and upload a CSV export from your bank or accounting
              software. InsightHunter parses and categorizes transactions automatically.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-number" aria-hidden="true">03</div>
          <div class="step-content">
            <h3 class="step-title">Get your Insight Pack</h3>
            <p class="step-body">
              Your dashboard populates instantly with P&amp;L, cash flow trends, and KPIs.
              Standard and Pro users get a one-click branded PDF Insight Pack ready to send.
            </p>
          </div>
        </li>
        <li class="step">
          <div class="step-number" aria-hidden="true">04</div>
          <div class="step-content">
            <h3 class="step-title">Let AI handle the rest</h3>
            <p class="step-body">
              Set up automated reminders, let the AI CFO forecast your next quarter,
              and get alerts before cash flow problems hit — not after.
            </p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ─── PRICING ──────────────────────────────────────────────────────────── -->

  <section class="section" id="pricing" aria-labelledby="pricing-heading">
    <div class="container">
      <div class="section-label">Pricing</div>
      <h2 id="pricing-heading" class="section-heading">
        Start free. Scale when you're ready.
      </h2>
      <p class="section-body">
        No contracts. Cancel anytime. Every plan includes unlimited CSV uploads and core compliance tools.
      </p>

      <div class="pricing-grid">

        <PricingCard
          plan="lite"
          price={0}
          label="Lite"
          description="The essentials — free, forever."
          clients="Up to 3 clients"
          badge=""
          features={[
            "3 client profiles",
            "Manual CSV upload",
            "Basic compliance dashboard",
            "Standard report templates",
            "Email support",
          ]}
          lockedFeatures={[
            "Auto data ingestion",
            "Engagement letter generation",
            "Branded Insight Pack PDFs",
            "AI forecasting & chat",
            "White-label branding",
          ]}
          cta={{ label: "Get Started Free", href: "/auth/signup" }}
          highlighted={false}
        />

        <PricingCard
          plan="standard"
          price={49}
          label="Standard"
          description="Everything you need to run a lean practice."
          clients="Up to 20 clients"
          badge="Most Popular"
          features={[
            "20 client profiles",
            "Auto data ingestion",
            "Full compliance hub + due dates",
            "Engagement letter generation + e-sign",
            "Branded Insight Pack PDFs",
            "KPI dashboards + cash flow alerts",
            "AI CFO assistant (chat + forecast)",
            "Priority email support",
          ]}
          lockedFeatures={[
            "White-label branding",
            "Multi-entity management",
            "Dedicated account manager",
          ]}
          cta={{ label: "Start Standard — $49/mo", href: "/auth/signup?plan=standard" }}
          highlighted={true}
        />

        <PricingCard
          plan="pro"
          price={149}
          label="Pro"
          description="For fractional CFOs managing multiple firms."
          clients="Unlimited clients"
          badge="For CFO Firms"
          features={[
            "Unlimited client profiles",
            "Everything in Standard",
            "White-label branding on all reports",
            "Multi-entity management",
            "Scenario modeling (AI)",
            "Multi-client performance comparison",
            "Advanced automation rules",
            "Dedicated account manager",
          ]}
          lockedFeatures={[]}
          cta={{ label: "Start Pro — $149/mo", href: "/auth/signup?plan=pro" }}
          highlighted={false}
        />

      </div>

      <!-- One-off report CTA -->
      <div class="oneoff-cta">
        <p>
          Need a single report without a subscription?
          <a href="/shop" class="link-accent">Get a one-off Insight Report for $100 →</a>
        </p>
      </div>

      <!-- Interactive plan selector island -->
      <PlanSelector client:visible />

    </div>
  </section>

  <!-- ─── TESTIMONIALS ─────────────────────────────────────────────────────── -->

  <section class="section section--alt" id="testimonials" aria-labelledby="testimonials-heading">
    <div class="container">
      <div class="section-label">From Our Users</div>
      <h2 id="testimonials-heading" class="section-heading sr-only">What people are saying</h2>

      <div class="testimonials-grid">

        <blockquote class="testimonial">
          <p class="testimonial-quote">
            "I manage 14 clients as a fractional CFO. InsightHunter cut my monthly reporting
            time from two full days down to about three hours. The white-label PDFs look
            more professional than anything I was producing manually."
          </p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true">SC</div>
            <div>
              <cite class="testimonial-name">Sarah C.</cite>
              <span class="testimonial-role">Fractional CFO, Atlanta</span>
            </div>
          </footer>
        </blockquote>

        <blockquote class="testimonial">
          <p class="testimonial-quote">
            "As a freelance consultant I always felt like I was guessing about my cash position.
            The forecast alert caught a shortfall two months before it hit. That alone paid
            for the subscription."
          </p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true">MR</div>
            <div>
              <cite class="testimonial-name">Marcus R.</cite>
              <span class="testimonial-role">Independent Strategy Consultant</span>
            </div>
          </footer>
        </blockquote>

        <blockquote class="testimonial">
          <p class="testimonial-quote">
            "The compliance hub is the feature I didn't know I needed. I used to track
            deadlines in a spreadsheet. Now I get automated reminders and my clients
            actually see me as more organized."
          </p>
          <footer class="testimonial-footer">
            <div class="testimonial-avatar" aria-hidden="true">LP</div>
            <div>
              <cite class="testimonial-name">Lisa P.</cite>
              <span class="testimonial-role">Bookkeeping & Tax Firm Owner</span>
            </div>
          </footer>
        </blockquote>

      </div>
    </div>
  </section>

  <!-- ─── FOR FIRMS CTA ────────────────────────────────────────────────────── -->

  <section class="section section--firms" aria-labelledby="firms-heading">
    <div class="container container--narrow">
      <div class="section-label">For Accounting Firms</div>
      <h2 id="firms-heading" class="section-heading section-heading--light">
        Your brand. Your clients.<br />Our infrastructure.
      </h2>
      <p class="section-body section-body--light">
        Pro plan gives your firm fully white-labeled reports, multi-client dashboards,
        and an AI CFO assistant that works with your data — delivered under your brand,
        not ours.
      </p>
      <div class="cta-row">
        <a href="/auth/signup?plan=pro" class="btn btn--primary-light">
          Start Pro Free Trial
        </a>
        <a href="/features/insight-pro" class="btn btn--ghost-light">
          View Firm Features →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FINAL CTA ────────────────────────────────────────────────────────── -->

  <section class="section section--cta" aria-labelledby="cta-heading">
    <div class="container container--narrow text-center">
      <h2 id="cta-heading" class="cta-heading">
        Your first insight is 5 minutes away.
      </h2>
      <p class="cta-body">
        Free tier. No credit card. No time limit.<br />
        Add your first client and see your numbers the way a CFO sees them.
      </p>
      <div class="cta-row cta-row--centered">
        <a href="/auth/signup" class="btn btn--primary btn--large">
          Create Free Account
        </a>
        <a href="/features/insight-lite" class="btn btn--ghost">
          Explore Lite Features
        </a>
      </div>
      <p class="cta-fine">
        Already have an account?
        <a href="/auth/login" class="link-muted">Sign in →</a>
      </p>
    </div>
  </section>

  <Footer />

</MarketingLayout>


<style>
  /* ─── Proof Bar ───────────────────────────────────────────────────────────── */
  .proof-bar {
    background: var(--color-surface-alt);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 1rem 0;
  }
  .proof-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem 2.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
  .proof-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  /* ─── Section Base ────────────────────────────────────────────────────────── */
  .section {
    padding: 5rem 0;
  }
  .section--alt {
    background: var(--color-surface-alt);
  }
  .section--firms {
    background: var(--color-brand);
    color: #fff;
  }
  .section--cta {
    background: var(--color-surface);
    padding: 6rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .container--narrow {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
  }
  .section-heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: 1rem;
  }
  .section-heading--light {
    color: #fff;
  }
  .section-body {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 600px;
    margin-bottom: 3rem;
    line-height: 1.6;
  }
  .section-body--light {
    color: rgba(255, 255, 255, 0.8);
  }
  .text-accent {
    color: var(--color-brand);
  }
  .text-center {
    text-align: center;
  }

  /* ─── Comparison Grid ─────────────────────────────────────────────────────── */
  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0;
    margin-top: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
  }
  .comparison-col {
    padding: 2rem;
  }
  .comparison-head {
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-border);
  }
  .comparison-head--bad { color: var(--color-text-muted); }
  .comparison-head--good { color: var(--color-brand); }
  .comparison-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-text-muted);
    background: var(--color-border);
    padding: 0 0.75rem;
    writing-mode: vertical-lr;
    letter-spacing: 0.1em;
  }
  .comparison-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    font-size: 0.9375rem;
  }
  .comparison-list--bad li::before {
    content: "✗  ";
    color: var(--color-danger, #ef4444);
    font-weight: 700;
  }
  .comparison-list--good li::before {
    content: "✓  ";
    color: var(--color-success, #22c55e);
    font-weight: 700;
  }

  /* ─── Features Grid ───────────────────────────────────────────────────────── */
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  /* ─── Steps ───────────────────────────────────────────────────────────────── */
  .steps-list {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .step {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1.5rem;
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .step:last-child {
    border-bottom: none;
  }
  .step-number {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-brand);
    opacity: 0.25;
    line-height: 1;
    padding-top: 0.2rem;
  }
  .step-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }
  .step-body {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ─── Pricing Grid ────────────────────────────────────────────────────────── */
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    align-items: start;
  }
  .oneoff-cta {
    margin-top: 2rem;
    text-align: center;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }
  .link-accent {
    color: var(--color-brand);
    text-decoration: none;
    font-weight: 600;
  }
  .link-accent:hover { text-decoration: underline; }

  /* ─── Testimonials ────────────────────────────────────────────────────────── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .testimonial {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.75rem;
    margin: 0;
  }
  .testimonial-quote {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    font-style: italic;
  }
  .testimonial-footer {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .testimonial-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-brand);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .testimonial-name {
    display: block;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-text);
    font-style: normal;
  }
  .testimonial-role {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  /* ─── For Firms CTA ───────────────────────────────────────────────────────── */
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }
  .cta-row--centered {
    justify-content: center;
  }

  /* ─── Final CTA ───────────────────────────────────────────────────────────── */
  .cta-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 1rem;
    line-height: 1.15;
  }
  .cta-body {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  .cta-fine {
    margin-top: 1.5rem;
    font-size: 0.875rem;
