---
import AuthLayout from "@/layouts/AuthLayout.astro";

// Validate the reset token present in the URL
const token = Astro.url.searchParams.get("token");
const isTokenMissing = !token;
---

<AuthLayout title="Reset Password">

  {isTokenMissing ? (
    <!-- Invalid / expired link state -->
    <div class="text-center space-y-4">
      <div class="text-4xl">🔗</div>
      <h1 class="text-xl font-semibold text-white">Link Invalid or Expired</h1>
      <p class="text-sm text-slate-400">
        This password reset link is no longer valid. Reset links expire after 1 hour.
      </p>
      <a
        href="/auth/forgot-password"
        class="inline-block w-full text-center mt-2 py-2.5 px-4 rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white font-medium text-sm transition-colors"
      >
        Request a New Link
      </a>
    </div>
  ) : (
    <!-- Reset password form -->
    <>
      <div class="mb-6">
        <h1 class="text-2xl font-semibold text-white">Set New Password</h1>
        <p class="text-sm text-slate-400 mt-1">
          Enter a strong new password for your account.
        </p>
      </div>

      <!-- Success banner (hidden by default) -->
      <div
        id="success-banner"
        role="status"
        aria-live="polite"
        class="hidden mb-4 rounded-lg bg-emerald-900/50 border border-emerald-700 px-4 py-3 text-sm text-emerald-300"
      >
        ✓ Password updated! Redirecting to login…
      </div>

      <!-- Error banner (hidden by default) -->
      <div
        id="error-banner"
        role="alert"
        aria-live="assertive"
        class="hidden mb-4 rounded-lg bg-red-900/50 border border-red-700 px-4 py-3 text-sm text-red-300"
      >
        Something went wrong. Please try again.
      </div>

      <form id="reset-form" novalidate class="space-y-5">
        <input type="hidden" name="token" value={token} />

        <div class="space-y-1.5">
          <label
            for="password"
            class="block text-sm font-medium text-slate-300"
          >
            New Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            required
            minlength="8"
            autocomplete="new-password"
            placeholder="At least 8 characters"
            class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white placeholder:text-slate-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition"
          />
          <p id="password-hint" class="text-xs text-slate-500">
            Minimum 8 characters, mix of letters and numbers recommended.
          </p>
        </div>

        <div class="space-y-1.5">
          <label
            for="confirm-password"
            class="block text-sm font-medium text-slate-300"
          >
            Confirm Password
          </label>
          <input
            id="confirm-password"
            name="confirmPassword"
            type="password"
            required
            autocomplete="new-password"
            placeholder="Repeat your new password"
            class="w-full rounded-lg border border-slate-700 bg-slate-800 px-3.5 py-2.5 text-sm text-white placeholder:text-slate-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500 transition"
          />
          <p
            id="mismatch-hint"
            class="hidden text-xs text-red-400"
            aria-live="polite"
          >
            Passwords do not match.
          </p>
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="w-full rounded-lg bg-indigo-600 hover:bg-indigo-500 disabled:bg-slate-700 disabled:cursor-not-allowed px-4 py-2.5 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-indigo-400"
        >
          Reset Password
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-slate-500">
        Remember it?
        <a
          href="/auth/login"
          class="text-indigo-400 hover:text-indigo-300 font-medium underline underline-offset-2 transition-colors"
        >
          Back to login
        </a>
      </p>
    </>
  )}

</AuthLayout>

<script>
  const form = document.getElementById("reset-form") as HTMLFormElement | null;
  if (!form) throw new Error("Reset form not found");

  const passwordInput   = document.getElementById("password")         as HTMLInputElement;
  const confirmInput    = document.getElementById("confirm-password") as HTMLInputElement;
  const mismatchHint    = document.getElementById("mismatch-hint")!;
  const submitBtn       = document.getElementById("submit-btn")       as HTMLButtonElement;
  const successBanner   = document.getElementById("success-banner")!;
  const errorBanner     = document.getElementById("error-banner")!;

  // Live mismatch check
  confirmInput.addEventListener("input", () => {
    const mismatch = confirmInput.value.length > 0 && passwordInput.value !== confirmInput.value;
    mismatchHint.classList.toggle("hidden", !mismatch);
    confirmInput.classList.toggle("border-red-500", mismatch);
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Client-side validation
    if (passwordInput.value !== confirmInput.value) {
      mismatchHint.classList.remove("hidden");
      confirmInput.focus();
      return;
    }

    if (passwordInput.value.length < 8) {
      passwordInput.focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = "Updating…";
    errorBanner.classList.add("hidden");

    try {
      const formData = new FormData(form);
      const response = await fetch("/api/auth/reset-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          token: formData.get("token"),
          password: formData.get("password"),
        }),
      });

      if (!response.ok) {
        const data = await response.json().catch(() => ({}));
        throw new Error((data as { message?: string }).message ?? "Reset failed");
      }

      // Success — show banner and redirect
      successBanner.classList.remove("hidden");
      form.classList.add("hidden");
      setTimeout(() => (window.location.href = "/auth/login?reset=success"), 2500);
    } catch (err) {
      const msg = err instanceof Error ? err.message : "Something went wrong.";
      errorBanner.textContent = `✗ ${msg}`;
      errorBanner.classList.remove("hidden");
      submitBtn.disabled = false;
      submitBtn.textContent = "Reset Password";
    }
  });
</script>
