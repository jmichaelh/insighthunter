{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target":           "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib":              ["ES2022", "DOM", "DOM.Iterable"],
    "types":            ["@cloudflare/workers-types", "astro/client"],
    "strict":           true,
    "noEmit":           true,
    "jsx":              "preserve",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "functions/**/*"]
}
