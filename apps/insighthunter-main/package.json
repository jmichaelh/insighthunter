{
  "name": "insighthunter-main",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "deploy": "npm run build && wrangler pages deploy .svelte-kit/cloudflare",
    "cf:dev": "wrangler pages dev .svelte-kit/cloudflare --compatibility-date=2025-03-07",
    "db:init": "wrangler d1 migrations apply INSIGHTHUNTER_DB --local",
    "db:deploy": "wrangler d1 migrations apply INSIGHTHUNTER_DB"
  },
  "dependencies": {
    "@sveltejs/adapter-cloudflare": "^4.7.0",
    "@sveltejs/kit": "^2.5.28",
    "svelte": "^4.2.19",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "@types/node": "^20.14.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "svelte-check": "^3.8.6",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.0",
    "vite": "^5.3.3"
  }
}
