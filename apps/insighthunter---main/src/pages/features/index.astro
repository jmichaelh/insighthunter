---
import MarketingLayout         from '@/layouts/MarketingLayout.astro';
import AppCard                 from '@/components/marketing/AppCard.astro';
import FeatureGrid             from '@/components/marketing/FeatureGrid.astro';
import SectionHeader           from '@/components/marketing/SectionHeader.astro';
import { FEATURES, getFeaturesByCategory } from '@/data/features';
import { APPS }                from '@/data/apps';
import type { FeatureCategory } from '@/data/features';

const CATEGORIES: { key: FeatureCategory; label: string; icon: string; description: string }[] = [
  { key: 'analytics',     label: 'Analytics',       icon: '📊', description: 'Real-time KPIs, burn rate, runway, and cash forecasting.' },
  { key: 'reporting',     label: 'Reports',          icon: '📋', description: 'GAAP-structured P&L, balance sheet, and cash flow exports.' },
  { key: 'ai',            label: 'AI CFO',           icon: '🤖', description: 'Insights, anomaly detection, and plain-English financial chat.' },
  { key: 'bookkeeping',   label: 'Bookkeeping',      icon: '📒', description: 'Chart of accounts, bank feeds, reconciliation, journal entries.' },
  { key: 'formation',     label: 'Formation',        icon: '🏛️', description: 'AI entity wizard, EIN guidance, compliance calendar.' },
  { key: 'payroll',       label: 'Payroll',          icon: '💸', description: 'Payroll runs, W-4 / 1099 management, journal sync.' },
  { key: 'integrations',  label: 'Integrations',     icon: '🔗', description: 'QuickBooks, Xero, and Plaid bank feeds.' },
  { key: 'collaboration', label: 'Collaboration',    icon: '👥', description: 'Team seats, white-label branding, and client workspaces.' },
  { key: 'platform',      label: 'Platform',         icon: '⚙️', description: 'PWA, 99.99% SLA, and dedicated onboarding.' },
];
---

<MarketingLayout
  title="Features — InsightHunter"
  description="Everything InsightHunter can do — from real-time KPIs and AI CFO insights to entity formation and bank reconciliation."
>

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="features-hero">
    <div class="features-hero__inner">
      <p class="features-hero__eyebrow">Everything in one place</p>
      <h1 class="features-hero__title">
        The financial OS for<br />
        <span class="gradient-text">growing businesses</span>
      </h1>
      <p class="features-hero__sub">
        From entity formation to AI-powered forecasting — InsightHunter replaces
        five separate tools with one integrated platform.
      </p>
      <div class="features-hero__ctas">
        <a href="/auth/register" class="btn btn--primary btn--lg">Start for Free</a>
        <a href="/pricing"       class="btn btn--ghost   btn--lg">See Pricing →</a>
      </div>
    </div>
  </section>

  <!-- ── Category nav ──────────────────────────────────────────── -->
  <nav class="features-cat-nav" aria-label="Feature categories">
    <div class="features-cat-nav__inner">
      {CATEGORIES.map(cat => (
        <a href={`#${cat.key}`} class="cat-nav-pill">
          <span aria-hidden="true">{cat.icon}</span>
          {cat.label}
        </a>
      ))}
    </div>
  </nav>

  <!-- ── Products section ──────────────────────────────────────── -->
  <section class="section">
    <div class="section__inner">
      <SectionHeader
        eyebrow="Products"
        title="Purpose-built apps, fully integrated"
        sub="Each app solves one problem perfectly — together they cover your entire financial stack."
      />
      <div class="apps-grid">
        {APPS.map(app => (
          <AppCard app={app} showFeatures={true} />
        ))}
      </div>
    </div>
  </section>

  <!-- ── Per-category feature sections ─────────────────────────── -->
  {CATEGORIES.map(cat => {
    const features = getFeaturesByCategory(cat.key);
    if (features.length === 0) return null;
    return (
      <section class="section section--alt" id={cat.key}>
        <div class="section__inner">
          <SectionHeader
            eyebrow={cat.icon + ' ' + cat.label}
            title={cat.description}
          />
          <FeatureGrid features={features} />
          <div class="section__cta">
            <a href={`/features/${cat.key}`} class="btn btn--outline">
              Learn more about {cat.label} →
            </a>
          </div>
        </div>
      </section>
    );
  })}

  <!-- ── Bottom CTA ─────────────────────────────────────────────── -->
  <section class="features-cta">
    <div class="features-cta__inner">
      <h2>Ready to replace five tools with one?</h2>
      <p>Free tier available — no credit card required.</p>
      <div class="features-cta__btns">
        <a href="/auth/register" class="btn btn--primary btn--lg">Get Started Free</a>
        <a href="/pricing"       class="btn btn--ghost   btn--lg">Compare Plans</a>
      </div>
    </div>
  </section>

</MarketingLayout>

<style>
  /* ── Hero ────────────────────────────────────────────────────── */
  .features-hero {
    background:    var(--color-sand-50);
    border-bottom: 1px solid var(--color-border);
    padding:       5rem 1.5rem 4rem;
    text-align:    center;
  }
  .features-hero__inner { max-width: 720px; margin: auto; }
  .features-hero__eyebrow {
    font-size:      0.8rem;
    font-weight:    700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color:          var(--color-primary);
    margin-bottom:  0.75rem;
  }
  .features-hero__title {
    font-size:   3rem;
    font-weight: 900;
    line-height: 1.1;
    color:       var(--color-text);
    margin-bottom: 1.25rem;
  }
  .gradient-text {
    background:              linear-gradient(135deg, var(--color-sand-600), var(--color-sand-800));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip:         text;
  }
  .features-hero__sub {
    font-size:     1.05rem;
    color:         var(--color-text-muted);
    line-height:   1.7;
    margin-bottom: 2rem;
  }
  .features-hero__ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  /* ── Category nav pill bar ───────────────────────────────────── */
  .features-cat-nav {
    background:    #fff;
    border-bottom: 1px solid var(--color-border);
    position:      sticky;
    top:           64px;
    z-index:       99;
    overflow-x:    auto;
  }
  .features-cat-nav__inner {
    display:     flex;
    gap:         4px;
    padding:     10px 1.5rem;
    max-width:   1200px;
    margin:      auto;
  }
  .cat-nav-pill {
    display:       flex;
    align-items:   center;
    gap:           5px;
    padding:       6px 14px;
    border-radius: 999px;
    font-size:     0.8rem;
    font-weight:   600;
    color:         var(--color-text-muted);
    text-decoration: none;
    white-space:   nowrap;
    transition:    background 0.12s, color 0.12s;
  }
  .cat-nav-pill:hover {
    background: var(--color-sand-100);
    color:      var(--color-text);
    text-decoration: none;
  }

  /* ── Sections ────────────────────────────────────────────────── */
  .section {
    padding: 5rem 1.5rem;
  }
  .section--alt { background: var(--color-sand-50); }
  .section__inner { max-width: 1100px; margin: auto; }

  .apps-grid {
    display:               grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap:                   1.25rem;
    margin-top:            2.5rem;
  }

  .section__cta { margin-top: 2rem; text-align: center; }

  /* ── Bottom CTA ──────────────────────────────────────────────── */
  .features-cta {
    background:    var(--color-sand-800);
    color:         #fff;
    padding:       5rem 1.5rem;
    text-align:    center;
  }
  .features-cta__inner { max-width: 600px; margin: auto; }
  .features-cta h2 { font-size: 2.25rem; font-weight: 800; margin-bottom: 0.75rem; }
  .features-cta p  { color: var(--color-sand-300); margin-bottom: 2rem; }
  .features-cta__btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 640px) {
    .features-hero__title { font-size: 2rem; }
  }
</style>
