---
// apps/insighthunter-auth/src/pages/auth/logout.astro
import { deleteSession } from '../../lib/auth';

const token = Astro.cookies.get('auth_token')?.value;
if (token) {
  await deleteSession(Astro.locals.runtime.env, token);
}

Astro.cookies.delete('auth_token', { path: '/', Domain: '.insighthunter.app' });
return Astro.redirect('/auth/login');
---
