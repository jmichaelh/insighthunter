---
import MarketingLayout from '/home/user/insighthunter/apps/insighthunter-main/src/layouts/MarketingLayout.astro';
import ResetPasswordForm from '../../components/islands/auth/ResetPasswordForm.svelte';

const token = Astro.url.searchParams.get('token') ?? '';
if (!token) return Astro.redirect('/auth/forgot-password');
---
<MarketingLayout title="Set New Password — InsightHunter" noContainer>
  <ResetPasswordForm client:load token={token} />
</MarketingLayout>
