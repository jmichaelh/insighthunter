---
// apps/insighthunter-auth/src/pages/auth/login.astro
import AuthLayout from '../../layouts/AuthLayout.astro';
import LoginForm from '../../components/islands/auth/LoginForm.svelte';

if (Astro.locals.userId) {
  return Astro.redirect('https://lite.insighthunter.app');
}

const redirectTo  = Astro.url.searchParams.get('redirect') ?? 'https://lite.insighthunter.app';
const siteKey     = Astro.locals.runtime.env.TURNSTILE_SITE_KEY ?? '';
---
<AuthLayout title="Sign In — InsightHunter">
  <LoginForm
    client:load
    redirectTo={redirectTo}
    turnstileSiteKey={siteKey}
  />
</AuthLayout>
