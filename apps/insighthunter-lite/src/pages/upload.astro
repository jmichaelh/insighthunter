---
// apps/insighthunter-lite/src/pages/upload.astro
import DashboardLayout from '../layouts/DashboardLayout.astro';
import CSVUploader from '../components/islands/CSVUploader.svelte';
---

<DashboardLayout title="Upload Transactions — Insight Lite">
  <div class="upload-page">
    <header class="page-header">
      <h1>Upload Transactions</h1>
      <p>Upload a CSV export from your bank or accounting tool. We'll generate your P&L, cash flow, and AI insights instantly.</p>
    </header>

    <section class="sample-hint">
      <a href="/sample-transactions.csv" download class="btn-secondary">
        ↓ Download sample CSV
      </a>
      <span class="hint-text">Columns needed: date, description, amount</span>
    </section>

    <!-- Svelte island: interactive upload + results -->
    <CSVUploader client:load />
  </div>
</DashboardLayout>

<style>
  .upload-page   { max-width: 800px; margin: 0 auto; padding: 2rem 1rem; }
  .page-header   { margin-bottom: 1.5rem; }
  .page-header h1 { font-size: 1.75rem; font-weight: 700; }
  .page-header p  { color: var(--color-muted); margin-top: 0.5rem; }
  .sample-hint   { display: flex; align-items: center; gap: 1rem; margin-bottom: 2rem; }
  .btn-secondary { padding: 0.5rem 1rem; border: 1px solid var(--color-border); border-radius: 6px; font-size: 0.875rem; text-decoration: none; }
  .hint-text     { font-size: 0.8rem; color: var(--color-muted); }
</style>
