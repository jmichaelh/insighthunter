---
interface Props { title?: string; description?: string }
const { title = "Insight Hunter", description = "Financial analytics for growing businesses." } = Astro.props;
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} | InsightHunter</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="h-full flex flex-col items-center justify-center px-4 py-12 relative">

    <!-- Ambient orbs -->
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-96 h-96 rounded-full blur-3xl opacity-20 pointer-events-none"
      style="background: radial-gradient(circle, #7c3aed, transparent)"></div>
    <div class="fixed bottom-0 right-0 w-64 h-64 rounded-full blur-3xl opacity-10 pointer-events-none"
      style="background: radial-gradient(circle, #06b6d4, transparent)"></div>

    <!-- Logo -->
    <div class="mb-8 flex flex-col items-center gap-3 relative z-10">
      <div class="w-14 h-14 rounded-2xl flex items-center justify-center font-black text-xl text-white shadow-2xl"
        style="background: linear-gradient(135deg,#7c3aed,#3b82f6); box-shadow: 0 0 32px rgba(124,58,237,0.5);">
        IH
      </div>
      <div class="text-center">
        <p class="font-black text-lg tracking-wider text-gradient">INSIGHTHUNTER</p>
        <p class="text-[10px] font-bold tracking-widest text-violet-400 uppercase">Lite Edition</p>
      </div>
    </div>

    <!-- Card -->
    <div class="w-full max-w-md relative z-10 rounded-2xl px-8 py-10 card-glow"
      style="background: rgba(7,13,42,0.85); backdrop-filter: blur(20px);">
      <slot />
    </div>

    <!-- Footer -->
    <p class="mt-8 text-center text-xs text-slate-600 relative z-10">
      &copy; {new Date().getFullYear()} Insight Hunter &nbsp;&middot;&nbsp;
      <a href="/privacy" class="hover:text-slate-400 transition underline underline-offset-2">Privacy</a>
      &nbsp;&middot;&nbsp;
      <a href="/terms"   class="hover:text-slate-400 transition underline underline-offset-2">Terms</a>
    </p>

  </body>
</html>
