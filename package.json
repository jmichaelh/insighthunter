{
  "name": "insighthunter",
  "version": "3.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm run dev --parallel",
    "dev:main": "pnpm --filter insighthunter-main dev",
    "dev:lite": "pnpm --filter insighthunter-lite dev",
    "build": "pnpm --filter insighthunter-main build",
    "build:main": "pnpm --filter insighthunter-main build",
    "build:lite": "pnpm --filter insighthunter-lite build",
    "deploy": "npx wrangler pages deploy dist --project-name insighthunter",
    "deploy:main": "pnpm --filter insighthunter-main deploy",
    "deploy:lite": "pnpm --filter insighthunter-lite deploy",
    "typecheck": "pnpm run typecheck",
    "lint": "pnpm run lint",
    "clean": "pnpm run clean && rm -rf node_modules",
    "test": "jest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@vitest/runner": "2.0.4",
      "@vitest/snapshot": "2.0.4",
      "@sveltejs/vite-plugin-svelte": "^3.0.0"
    }
  }
}