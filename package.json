{
  "name": "insighthunter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev":          "turbo run dev --parallel",
    "dev:main":     "pnpm --filter insighthunter-main dev",
    "dev:lite":     "pnpm --filter insighthunter-lite dev",
    "build":        "turbo run build",
    "build:main":   "pnpm --filter insighthunter-main build",
    "build:lite":   "pnpm --filter insighthunter-lite build",
    "deploy":       "turbo run deploy",
    "deploy:main":  "pnpm --filter insighthunter-main deploy",
    "deploy:lite":  "pnpm --filter insighthunter-lite deploy",
    "typecheck":    "turbo run typecheck",
    "lint":         "turbo run lint",
    "clean":        "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo":      "^2.3.0",
    "typescript": "^5.7.0"
  }
}
