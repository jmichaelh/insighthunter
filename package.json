
{
  "name": "insighthunter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/types",
    "packages/utils",
    "packages/agents"
  ],
  "scripts": {
    "dev:main":    "cd apps/insighthunter-main && astro dev",
    "build:main":  "cd apps/insighthunter-main && astro build",
    "deploy:main": "cd apps/insighthunter-main && wrangler deploy",
    "dev":         "npm run dev:main",
    "deploy:all":  "npm run deploy:main && npm run deploy:auth && npm run deploy:agents"
  }
}
